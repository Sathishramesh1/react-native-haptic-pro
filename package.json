{
  "name": "react-native-haptic-pro",
  "version": "1.0.0",
  "description": "High-performance bridge-less haptic feedback module for React Native built with Nitro Modules.",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "sideEffects": false,
  "files": [
  "lib",
  "android",
   "nitrogen",
  "ios",
  "cpp",
  "*.podspec",
  "react-native.config.js",
  "LICENSE",
  "README.md"
],
  "scripts": {
    "example": "yarn workspace react-native-haptic-pro-example",
    "dev:android": "rm -f react-native-haptic-pro-*.tgz && npx nitrogen && npm run prepare && npm pack && TAR=$(ls react-native-haptic-pro-*.tgz | tail -n 1) && cd example && rm -rf node_modules/react-native-haptic-pro && npm install ../$TAR && npx react-native run-android",
    "dev:android:clean": "npx nitrogen && npm run prepare && npm pack && cd example && rm -rf node_modules/react-native-haptic-pro && npm install ../$(ls ../react-native-haptic-pro-*.tgz | tail -n 1) && cd android && ./gradlew clean && cd .. && npx react-native run-android",
    "clean": "del-cli android/build example/android/build example/android/app/build example/ios/build lib",
    "prepare": "bob build",
    "nitrogen": "nitrogen",
    "typecheck": "tsc",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "test": "jest",
    "release": "release-it --only-version"
  },
  "keywords": [
    "react-native",
    "react-native-library",
    "haptics",
    "haptic-feedback",
    "vibration",
    "native-module",
    "nitro-modules",
    "turbo-module",
    "bridge-less",
    "android",
    "ios"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sathishramesh1/react-native-haptic-pro.git"
  },
  "author": "sathish <sathishrameshkec@gmail.com> (https://github.com/Sathishramesh1)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Sathishramesh1/react-native-haptic-pro/issues"
  },
  "homepage": "https://github.com/Sathishramesh1/react-native-haptic-pro#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/compat": "^1.3.2",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.35.0",
    "@react-native/babel-preset": "0.83.0",
    "@react-native/eslint-config": "0.83.0",
    "@release-it/conventional-changelog": "^10.0.1",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.2.0",
    "commitlint": "^19.8.1",
    "del-cli": "^6.0.0",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-ft-flow": "^3.0.11",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react-native": "^5.0.0",
    "jest": "^29.7.0",
    "lefthook": "^2.0.3",
    "nitrogen": "^0.33.9",
    "prettier": "^3.0.0",
    "react": "19.2.0",
    "react-native": "0.83.0",
    "react-native-builder-bob": "^0.40.13",
    "react-native-nitro-modules": "^0.33.9",
    "release-it": "^19.0.4",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.71",
    "react-native-nitro-modules": "^0.33.9"
  },
  "packageManager": "yarn@4.11.0",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "custom",
        {
          "script": "nitrogen",
          "clean": "nitrogen/"
        }
      ],
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "jest": {
    "preset": "react-native",
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release ${version}",
      "tagName": "v${version}"
    },
    "npm": {
      "publish": true
    },
    "github": {
      "release": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": {
          "name": "angular"
        }
      }
    }
  },
  "create-react-native-library": {
    "type": "nitro-module",
    "languages": "kotlin-swift",
    "tools": [
      "eslint",
      "jest",
      "lefthook",
      "release-it"
    ],
    "version": "0.57.2"
  },
  "exports": {
    ".": {
      "types": "./lib/typescript/src/index.d.ts",
      "import": "./lib/module/index.js",
      "require": "./lib/module/index.js"
    }
  }
}
